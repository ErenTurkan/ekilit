{
  "expo": {
    "name": "E-Kilit Öğretmen",
    "slug": "ekilit-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#050816"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      },
      "package": "com.ekilit.mobile",
      "permissions": [
        "CAMERA"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod okutmak için kamera izni gereklidir."
        }
      ],
      "expo-asset"
    ]
  }
}
