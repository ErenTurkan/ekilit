{
  "name": "e-kilit-admin",
  "version": "1.0.0",
  "description": "E-Kilit Yönetim Paneli",
  "main": "main/index.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "electron:dev": "concurrently \"next dev -p 3001\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.50.0",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.0",
    "diskusage-ng": "^1.0.4",
    "framer-motion": "^11.0.0",
    "fs-extra": "^11.3.4",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "node-disk-info": "^1.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.8.0",
    "sudo-prompt": "^9.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ekilit.admin",
    "productName": "E-Kilit Yönetim Paneli",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
