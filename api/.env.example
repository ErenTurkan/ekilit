# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for development, MySQL for production)
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ekilit
DB_USER=root
DB_PASS=your_password_here

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Master Key
MASTER_KEY_SECRET=your-master-key-secret-change-this

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
